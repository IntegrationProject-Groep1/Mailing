RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=mailing
RABBITMQ_PASS=mailing
RABBITMQ_VHOST=/

SENDGRID_API_KEY=SG.replace-me
FROM_EMAIL=alerts@example.com
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# SendGrid Dynamic Template IDs, one per contract mail_type (see §12.1).
# Each is a "d-..." identifier from the SendGrid dashboard.
# template_data variables expected by each template are documented in README.md.
SENDGRID_TEMPLATE_REGISTRATION_CONFIRMATION=d-replace-me
SENDGRID_TEMPLATE_PAYMENT_CONFIRMATION=d-replace-me
SENDGRID_TEMPLATE_INVOICE_READY=d-replace-me
SENDGRID_TEMPLATE_SESSION_UPDATE=d-replace-me
SENDGRID_TEMPLATE_GENERAL_ANNOUNCEMENT=d-replace-me

# Phase 2: when true, the consumer also publishes WARN+ log records to
# the shared `logs` queue via RabbitMQLogHandler. Off by default until
# the platform-team logs.xsd is signed off.
LOG_QUEUE_ENABLED=false
