<?xml version="1.0" encoding="UTF-8"?>
<!--
  INFO example — a successful send_mailing dispatch worth recording on the
  Logstash dashboard so we can chart campaign volume per source.
  correlation_id is set so this row joins to the inbound send_mailing on
  CRM's side.
-->
<message>
  <header>
    <message_id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</message_id>
    <timestamp>2026-05-15T18:35:01Z</timestamp>
    <source>mailing</source>
    <type>log</type>
    <version>2.0</version>
    <correlation_id>c3d4e5f6-a7b8-9012-cdef-012345678902</correlation_id>
  </header>
  <body>
    <level>INFO</level>
    <action>sendgrid_dispatch</action>
    <logger>mailing_service.consumers.send_mailing</logger>
    <message>SendGrid accepted template send for campaign sg-campaign-0089</message>
    <context>
      <entry key="campaign_id">sg-campaign-0089</entry>
      <entry key="mail_type">registration_confirmation</entry>
      <entry key="recipient_count">1</entry>
      <entry key="source_queue">crm.to.mailing</entry>
    </context>
  </body>
</message>
